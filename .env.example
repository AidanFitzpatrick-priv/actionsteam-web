# DATABASE_URL — Railway: reference Postgres service; local: see below
DATABASE_URL="postgresql://actions:actions_dev@localhost:5432/actions"

# Public URL (invite links) — production: https://actionsteam.xyz
APP_URL="http://localhost:3000"

# Bootstrap management user (first deploy only)
SEED_ADMIN_EMAIL="you@example.com"
SEED_ADMIN_USERNAME="admin"
# SEED_ADMIN_PASSWORD="your-secure-password"

# Node
NODE_ENV="development"
